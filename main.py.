import requests
from datetime import datetime, timedelta

# --- CONFIG ---
NTFY_TOPIC = "philly-win-alerts-1985" 
API_KEY = "123" # Updated to the current free key

TEAMS = {
    "Phillies": "135277",
    "Sixers": "134870",
    "Flyers": "134833",
    "Eagles": "134937"
}

def check_for_wins():
    now = datetime.now()
    today = now.strftime("%Y-%m-%d")
    yesterday = (now - timedelta(days=1)).strftime("%Y-%m-%d")
    print(f"Checking for games on {today} or {yesterday} (UTC)...")

    for team_name, team_id in TEAMS.items():
        try:
            print(f"--- Checking {team_name} ---")
            url = f"https://www.thesportsdb.com/api/v1/json/{API_KEY}/eventslast.php?id={team_id}"
            response = requests.get(url)
            
            if response.status_code != 200:
                print(f"Error: API returned status {response.status_code}")
                continue
                
            data = response.json()
            
            if not data or 'results' not in data or data['results'] is None:
                print(f"No recent game data found for {team_name}.")
                continue
            
            last_game = data['results'][0]
            game_date = last_game.get('dateEvent')
            print(f"Last game found was on {game_date}")
            
            if game_date in [today, yesterday]:
                home_team = last_game.get('strHomeTeam', 'Unknown')
                away_team = last_game.get('strAwayTeam', 'Unknown')
                
                # Convert scores to numbers, defaulting to 0 if missing
                h_score = int(last_game.get('intHomeScore') or 0)
                a_score = int(last_game.get('intAwayScore') or 0)
                
                victory = False
                if team_name in home_team and h_score > a_score:
                    victory = True
                elif team_name in away_team and a_score > h_score:
                    victory = True
                
                if victory:
                    msg = f"🏆 {team_name} WIN! Final: {home_team} {h_score} - {away_team} {a_score}"
                    requests.post(f"https://ntfy.sh/{NTFY_TOPIC}", data=msg.encode('utf-8'))
                    print(f"✅ Notification sent for {team_name}!")
                else:
                    print(f"No win for {team_name} (Score: {h_score}-{a_score})")
            else:
                print(f"Game on {game_date} is too old. Skipping.")

        except Exception as e:
            print(f"❌ Error checking {team_name}: {e}")

if __name__ == "__main__":
    check_for_wins()
